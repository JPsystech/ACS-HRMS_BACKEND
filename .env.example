# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/acs_hrms_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Application Environment
APP_ENV=local
# Options: local, staging, prod

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# CORS Configuration
# For local: use "*" to allow all origins
# For production: provide comma-separated list of allowed origins (e.g., "https://example.com,https://app.example.com")
ALLOWED_ORIGINS=*

# Timezone (for display/documentation; code stores UTC)
TZ=Asia/Kolkata

# Cloudflare R2 Configuration (Required for Profile Photos)
R2_ENDPOINT=https://4a52fb997e18ee346d9c38a489422e37.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=c558c987cfb40857726f6d1dfafa0306
R2_SECRET_ACCESS_KEY=56dc3739736eb62dda7f794caaf32b12c1f25833a0211c9081ea302bfd7f1cd2
R2_BUCKET=acs-hrms-storage

